# ============================================================
# Multimodal Conversational Agent — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# --- Server ---
HOST=0.0.0.0
PORT=8000
WORKERS=4
DEBUG=false

# --- Provider selection ---
LLM_PROVIDER=openai          # openai | anthropic | gemini
LLM_MODEL=gpt-4o
STT_PROVIDER=openai          # openai | gemini
STT_MODEL=whisper-1
TTS_PROVIDER=openai           # openai | gemini
TTS_MODEL=tts-1
TTS_VOICE=alloy

# --- API keys (set only the ones you need) ---
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AI...

# --- Model capabilities ---
LLM_SUPPORTS_AUDIO=false      # true if using a model that accepts audio natively
LLM_SUPPORTS_TOOLS=true

# --- UX ---
SHOW_USER_TRANSCRIPT=true     # Send transcribed user audio text to the client

# --- Input limits (security) ---
MAX_AUDIO_DURATION_SECONDS=120
MAX_AUDIO_SIZE_MB=25
MAX_TEXT_LENGTH=4096

# --- Retry limits ---
MAX_RETRIES_STT=3
MAX_RETRIES_TOOL=2
MAX_RETRIES_LLM=3
MAX_RETRIES_TTS=2

# --- Fault actions ---
STT_FAULT_ACTION=request_audio_retry    # request_audio_retry | end_session
TOOL_FAULT_ACTION=continue_without_tool # continue_without_tool | fallback_response
LLM_FAULT_ACTION=safe_response          # safe_response
TTS_FAULT_ACTION=text_only              # text_only

# --- Rate limiting ---
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_BURST=5

# --- Timeouts (seconds) ---
TIMEOUT_STT=30
TIMEOUT_LLM=60
TIMEOUT_TOOL=30
TIMEOUT_TTS=30

# --- Circuit breaker ---
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30

# --- Session ---
SESSION_TTL_SECONDS=1800
MAX_CONCURRENT_SESSIONS=50000

# --- Context compression (0 = disabled, no compression) ---
MAX_CONTEXT_MESSAGES=0              # Compress when messages[] exceeds this count
CONTEXT_KEEP_RECENT=5               # Recent turns to keep literal (not summarized)
CONTEXT_SUMMARY_MODEL=gpt-4o-mini   # Cheap model used for summarization

# --- Safe response message ---
SAFE_RESPONSE_MESSAGE=No pude procesar tu solicitud en este momento. Por favor, intenta de nuevo más tarde.
